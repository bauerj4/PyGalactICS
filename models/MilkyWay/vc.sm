erase
define TeX_strings 0
lweight 3
location 8000 26000 6000 25000
limits -1 41 -1 300
ctype 0 ltype 0
expand 1.3
box 
expand 1.6
xlabel r (kpc)

data vc.out
read {r 1 d 2 b 3 h 4 t 5}
set d = d*100
set h = h*100
set t = t*100
set b = b*100
connect r t
ctype red
connect r h
ctype blue 
connect r d
ctype green
connect r b


